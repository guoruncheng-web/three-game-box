# Database URL (PostgreSQL - Neon)
# Neon 连接池地址，用于 Prisma 查询
DATABASE_URL="postgresql://username:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Neon 直连地址，用于 Prisma Migrate / db push
DIRECT_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Next.js
NODE_ENV="development"
PORT=7006

# JWT Secret (生产环境请使用强密码)
JWT_SECRET="your-secret-key-here"

# Redis (可选，用于缓存)
REDIS_URL="redis://localhost:6379"
